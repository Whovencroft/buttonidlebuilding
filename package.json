  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^6.3.0",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/app": "^6.0.1",
    "@capacitor/android": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "phaser": "^3.90.0"
  }
}
